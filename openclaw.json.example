{
  "env": {
    "ANTHROPIC_API_KEY": "sk-ant-api03-..."
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-20250514"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "your-secret-token-here"
    }
  },
  "plugins": {
    "entries": {
      "learning-machine": {
        "enabled": true,
        "hooks": {
          "allowPromptInjection": true
        },
        "config": {
          "apiUrl": "http://agno-api:8000",
          "defaultChannel": "discord"
        }
      }
    }
  }
}
